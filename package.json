{
  "name": "donaciones-amazonas",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "db:migrate": "pnpm --filter @donaciones/backend exec prisma migrate dev",
    "db:seed": "pnpm --filter @donaciones/backend exec prisma db seed",
    "db:studio": "pnpm --filter @donaciones/backend exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.8.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "@swc/core",
      "@scarf/scarf",
      "esbuild"
    ]
  }
}
